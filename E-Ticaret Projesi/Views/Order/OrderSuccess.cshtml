@{
    ViewData["Title"] = "Sipariş Alındı";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7 col-xl-6">
            <div class="success-card text-center">
                <p class="eyebrow mb-2">Sipariş başarılı</p>
                <h1 class="section-title mb-3">Siparişin sisteme alındı</h1>
                <p class="text-muted mb-4">Ödeme formun tamamlandı ve sipariş kaydın oluşturuldu. Güncel durumları Siparişlerim ekranından takip edebilirsin.</p>
                <div class="d-flex flex-wrap justify-content-center gap-3">
                    <a asp-controller="Product" asp-action="Index" class="btn btn-amber">Alışverişe Devam Et</a>
                    <a asp-action="MyOrders" class="btn btn-outline-secondary">Siparişlerimi Gör</a>
                </div>
            </div>
        </div>
    </div>
</div>
