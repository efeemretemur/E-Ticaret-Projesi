@model List<Category>

@{
    ViewData["Title"] = "Kategori Yönetimi";
}

<div class="panel-card">
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">
        <div>
            <p class="eyebrow mb-2">Admin</p>
            <h2 class="section-title mb-0">Kategori Yönetimi</h2>
        </div>
        <a asp-action="Create" class="btn btn-amber">Yeni Kategori Ekle</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info mb-0">Henüz kategori bulunmuyor. İlk kategoriyi ekleyerek admin akışını başlatabilirsin.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table align-middle admin-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Kategori Adı</th>
                        <th>Açıklama</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model)
                    {
                        <tr>
                            <td>@category.Id</td>
                            <td>@category.Name</td>
                            <td>@(string.IsNullOrWhiteSpace(category.Description) ? "-" : category.Description)</td>
                            <td class="text-end">
                                <div class="d-inline-flex gap-2">
                                    <a asp-action="Edit" asp-route-id="@category.Id" class="btn btn-sm btn-outline-secondary">Düzenle</a>
                                    <form method="post" asp-action="Delete" asp-route-id="@category.Id" onsubmit="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                        <button type="submit" class="btn btn-sm btn-outline-danger">Sil</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
