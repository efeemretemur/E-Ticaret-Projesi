@model E_Ticaret_Projesi.ViewModels.AdminProductFormViewModel

@{
    ViewData["Title"] = "Ürün Düzenle";
    var categories = ViewBag.Categories as List<Category> ?? new List<Category>();
}

<div class="panel-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <p class="eyebrow mb-2">Admin</p>
            <h2 class="section-title mb-0">Ürünü Düzenle</h2>
        </div>
        <a asp-action="Index" class="btn btn-outline-secondary">Listeye Dön</a>
    </div>

    <form method="post" asp-action="Edit" enctype="multipart/form-data" class="row g-3">
        <input asp-for="Id" type="hidden" />
        <input asp-for="ExistingImageUrl" type="hidden" />
        <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Price" class="form-label"></label>
            <input asp-for="Price" class="form-control" placeholder="1250,50" />
            <span asp-validation-for="Price" class="text-danger small"></span>
        </div>
        <div class="col-md-3">
            <label asp-for="Stock" class="form-label"></label>
            <input asp-for="Stock" class="form-control" />
            <span asp-validation-for="Stock" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="CategoryId" class="form-label">Kategori</label>
            <select asp-for="CategoryId" class="form-select" asp-items="@(new SelectList(categories, nameof(Category.Id), nameof(Category.Name)))"></select>
            <span asp-validation-for="CategoryId" class="text-danger small"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="ImageFile" class="form-label"></label>
            <input asp-for="ImageFile" type="file" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
            <span asp-validation-for="ImageFile" class="text-danger small"></span>
            <small class="form-text">Yeni bir dosya yüklerseniz mevcut görselin yerini alır.</small>
        </div>
        <div class="col-md-6">
            <label asp-for="ImageUrl" class="form-label">Görsel Bağlantısı</label>
            <input asp-for="ImageUrl" class="form-control" placeholder="https://... veya /images/..." />
            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
            <small class="form-text">Bu alanı boş bırakırsanız mevcut görsel korunur.</small>
        </div>
        @if (!string.IsNullOrWhiteSpace(Model.ExistingImageUrl))
        {
            <div class="col-12">
                <p class="form-label mb-2">Mevcut Görsel</p>
                <img src="@Model.ExistingImageUrl" alt="@Model.Name" class="img-fluid rounded-4 border" style="max-height: 220px;" />
            </div>
        }
        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" rows="4" class="form-control"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-amber">Güncelle</button>
            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
