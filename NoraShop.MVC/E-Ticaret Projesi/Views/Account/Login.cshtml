@model LoginViewModel

@{
    ViewData["Title"] = "Giriş Yap";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-xl-5">
            <div class="auth-card">
                <p class="eyebrow mb-2">Üye Girişi</p>
                <h1 class="section-title mb-3">Hesabına geri dön</h1>
                <p class="text-muted">Kayıtlı hesabınızla giriş yaparak sepetinizi ve sipariş takibinizi kullanabilirsiniz.</p>

                <form method="post" asp-action="Login" class="mt-4 d-grid gap-3">
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <div>
                        <label asp-for="Email" class="form-label"></label>
                        <input asp-for="Email" class="form-control" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div>
                        <label asp-for="Password" class="form-label"></label>
                        <input asp-for="Password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-amber btn-lg">Giriş Yap</button>
                </form>

                <p class="text-muted small mt-4 mb-0">Hesabın yok mu? <a asp-action="Register">Kayıt ol</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
