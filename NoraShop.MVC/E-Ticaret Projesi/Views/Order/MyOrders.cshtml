@model List<Order>

@{
    ViewData["Title"] = "Siparişlerim";
}

<div class="container py-4">
    <div class="section-head d-flex flex-column flex-lg-row justify-content-between align-items-lg-end gap-3 mb-4">
        <div>
            <p class="eyebrow mb-2">Hesabım</p>
            <h1 class="section-title mb-0">Sipariş geçmişim</h1>
        </div>
        <a class="btn btn-outline-secondary" asp-controller="Product" asp-action="Index">Yeniden Alışveriş Yap</a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">Henüz siparişiniz bulunmuyor. İlk siparişinizi oluşturmak için ürünleri inceleyebilirsiniz.</div>
    }
    else
    {
        <div class="d-grid gap-4">
            @foreach (var order in Model)
            {
                var badgeClass = order.Status switch
                {
                    "Beklemede" => "bg-warning text-dark",
                    "Hazırlanıyor" => "bg-info text-dark",
                    "Kargoda" => "bg-primary",
                    "Teslim Edildi" => "bg-success",
                    "İptal Edildi" => "bg-danger",
                    _ => "bg-secondary"
                };

                <article class="order-card">
                    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3 mb-3">
                        <div>
                            <h2 class="h5 mb-1">Sipariş #@order.Id</h2>
                            <p class="text-muted mb-0">@order.OrderDate.ToString("dd.MM.yyyy HH:mm") tarihinde oluşturuldu.</p>
                        </div>
                        <div class="text-lg-end">
                            <span class="badge @badgeClass">@order.Status</span>
                            <div class="mt-2 fw-semibold">@order.TotalPrice.ToString("C")</div>
                        </div>
                    </div>

                    <div class="small text-muted mb-3">Teslimat Adresi: @order.Address</div>

                    <div class="row g-3">
                        @foreach (var item in order.OrderItems)
                        {
                            <div class="col-md-6">
                                <div class="order-item-row">
                                    <div>
                                        <strong>@(item.Product?.Name ?? "Silinmiş ürün")</strong>
                                        <div class="small text-muted">@item.Quantity adet</div>
                                    </div>
                                    <strong>@(item.UnitPrice.ToString("C"))</strong>
                                </div>
                            </div>
                        }
                    </div>
                </article>
            }
        </div>
    }
</div>
